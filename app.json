{
  "expo": {
    "name": "Sadhana",
    "slug": "sadhana",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sadhana",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F5F0E8",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.sadhana"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F0E8"
      },
      "package": "com.yourname.sadhana"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
